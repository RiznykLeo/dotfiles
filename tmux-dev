#!/bin/bash

# tmux-dev - Create a development tmux session with predefined layout
# Usage: tmux-dev [session_name]
# Author: Custom tmux development environment setup

set -euo pipefail  # Exit on error, undefined vars, pipe failures

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Function to print colored output
print_status() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Check if tmux is installed
if ! command -v tmux &> /dev/null; then
    print_error "tmux is not installed. Please install it first."
    exit 1
fi

# Determine session name
if [ $# -eq 1 ]; then
    SESSION_NAME="$1"
    # Sanitize session name (remove invalid characters)
    SESSION_NAME=$(echo "$SESSION_NAME" | sed 's/[^a-zA-Z0-9_-]/_/g')
else
    SESSION_NAME=$(basename "$(pwd)" | sed 's/[^a-zA-Z0-9_-]/_/g')
fi

# Check if session already exists
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    print_warning "Session '$SESSION_NAME' already exists. Attaching to it..."
    tmux attach-session -t "$SESSION_NAME"
    exit 0
fi

print_status "Creating tmux session '$SESSION_NAME' in $(pwd)"

# Create new tmux session in detached mode
tmux new-session -d -s "$SESSION_NAME" -c "$(pwd)"

# Window 0: Vertical split (50/50)
print_status "Setting up window 0: Terminal split"
tmux split-window -h -t "$SESSION_NAME:0" -c "$(pwd)"
tmux select-pane -t "$SESSION_NAME:0.0"

# Window 1: nvim
print_status "Setting up window 1: Neovim"
tmux new-window -t "$SESSION_NAME:1" -c "$(pwd)" -n "nvim"
if command -v nvim &> /dev/null; then
    tmux send-keys -t "$SESSION_NAME:1" "nvim ." Enter
else
    print_warning "nvim not found, using vim instead"
    tmux send-keys -t "$SESSION_NAME:1" "vim ." Enter
fi

# Window 2: lazygit
print_status "Setting up window 2: Lazygit"
tmux new-window -t "$SESSION_NAME:2" -c "$(pwd)" -n "lazygit"
if command -v lazygit &> /dev/null; then
    tmux send-keys -t "$SESSION_NAME:2" "lazygit" Enter
else
    print_warning "lazygit not found, opening regular git status"
    tmux send-keys -t "$SESSION_NAME:2" "git status" Enter
fi

# Window 3: Empty shell
print_status "Setting up window 3: Shell"
tmux new-window -t "$SESSION_NAME:3" -c "$(pwd)" -n "shell"

# Set window titles and options
tmux rename-window -t "$SESSION_NAME:0" "terminal"
tmux set-window-option -t "$SESSION_NAME" automatic-rename off

# Select window 0 by default and focus left pane
tmux select-window -t "$SESSION_NAME:0"
tmux select-pane -t "$SESSION_NAME:0.0"

print_status "Development environment ready! Session: $SESSION_NAME"
print_status "Windows: 0=terminal, 1=nvim, 2=lazygit, 3=shell"
print_status "Navigation: Ctrl+b + [0-3] to switch windows"

# Attach to the session
tmux attach-session -t "$SESSION_NAME"
